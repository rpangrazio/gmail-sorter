# =============================================================================
# Gmail AI Sorter — Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in the values.
# The .env file is loaded automatically at startup (never commit it to git).
# =============================================================================

# ---------------------------------------------------------------------------
# Required — set the key for whichever ai_provider you chose in config.yaml
# ---------------------------------------------------------------------------

# GitHub personal access token — required when ai_provider = copilot (default).
# The token must belong to an account with an active GitHub Copilot subscription.
# Obtain from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# OpenAI API key — required when ai_provider = openai.
# Obtain from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: override the OpenAI API base URL to use a compatible third-party
# endpoint (e.g. Azure OpenAI, OpenRouter, Ollama, etc.).
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# Optional — Paths (defaults shown; change only if needed)
# ---------------------------------------------------------------------------

# Path to the OAuth2 client secrets JSON downloaded from Google Cloud Console.
# In Docker this is mounted as a read-only volume from ./credentials/
# GOOGLE_CREDENTIALS_PATH=/credentials/credentials.json

# Path where the OAuth2 token file will be stored after first authorization.
# In Docker this is in a named volume so it survives container restarts.
# GOOGLE_TOKEN_PATH=/data/token.json

# Path to the agent state file (stores Gmail history ID and watch expiry).
# Used only when state_backend = "json" (the default).
# STATE_FILE_PATH=/data/state.json

# Path to the SQLite database file.
# Used only when state_backend = "sqlite".
# SQLITE_DB_PATH=/data/gmail_sorter.db

# PostgreSQL connection URL.
# Used only when state_backend = "postgres".
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# DATABASE_URL=postgresql://sorter:sorter@postgres:5432/gmail_sorter

# Path to the YAML configuration file.
# CONFIG_PATH=/app/config/config.yaml

# ---------------------------------------------------------------------------
# Optional — Overrides
# ---------------------------------------------------------------------------

# Override the log level set in config.yaml (DEBUG | INFO | WARNING | ERROR).
# LOG_LEVEL=INFO
