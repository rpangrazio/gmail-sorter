# Example environment variables for running gmail-sorter with docker-compose
# Copy this file to .env and fill in the values before running `docker-compose up`.

# Raw LLM API key to inject into the configured API envvar (LLM_API_KEY_ENV).
# If you already have a provider-specific env var (eg OPENAI_API_KEY) you can omit
# this and pass that env var directly to docker-compose instead.
LLM_API_KEY=your_llm_api_key_here

# Name of the env var that LlmClient expects (matches config.yaml.llm.api_key_env)
LLM_API_KEY_ENV=OPENAI_API_KEY

# Base URL for OpenAI-compatible providers (leave blank to use default behavior in config.yaml)
# Example: https://api.openai.com
LLM_BASE_URL=https://api.openai.com

# Optional Gmail OAuth credential paths (host paths that are mounted into the container)
GMAIL_CREDENTIALS_PATH=./data/credentials.json
GMAIL_TOKEN_PATH=./data/token.json
